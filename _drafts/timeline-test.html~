<style>
  .scaled-timeline {
    --start: 1955;
    --end: 2030;
    --year-step: 150px;   /* increase for more vertical spacing */
    --top-pad: 40px;
    --axis-x: 110px;
    --card-gap: 56px;

    --line: #d7dde5;
    --text: #0f172a;
    --muted: #5b6472;
    --card: #ffffff;
    --border: #e5e7eb;
    --accent: #2457ff;

    position: relative;
    max-width: 980px;
    margin: 3rem auto;
    min-height: calc((var(--end) - var(--start)) * var(--year-step) + (2 * var(--top-pad)));
  }

  .scaled-timeline::before {
    content: "";
    position: absolute;
    left: var(--axis-x);
    top: var(--top-pad);
    bottom: var(--top-pad);
    width: 2px;
    background: linear-gradient(
      to bottom,
      transparent 0%,
      var(--line) 4%,
      var(--line) 96%,
      transparent 100%
    );
  }

  .scaled-timeline__tick {
    position: absolute;
    left: var(--axis-x);
    top: calc(var(--top-pad) + (var(--year) - var(--start)) * var(--year-step));
    width: 0;
    height: 0;
  }

  .scaled-timeline__tick::before {
    content: "";
    position: absolute;
    left: 50%;
    top: 50%;
    width: 12px;
    height: 12px;
    border-radius: 999px;
    background: #fff;
    border: 2px solid var(--accent);
    transform: translate(-50%, -50%);
  }

  .scaled-timeline__label {
    position: absolute;
    right: 22px;
    top: 50%;
    transform: translateY(-50%);
    color: var(--text);
    font-size: 0.78rem;
    font-weight: 700;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    white-space: nowrap;
  }

  .scaled-timeline__event {
    position: absolute;
    left: calc(var(--axis-x) + var(--card-gap));
    top: calc(var(--top-pad) + (var(--year) - var(--start)) * var(--year-step) + var(--shift, 0px));
    transform: translateY(-50%);
    width: calc(100% - var(--axis-x) - var(--card-gap) - 20px);
  }

  .scaled-timeline__event::before {
    content: "";
    position: absolute;
    left: -36px;
    top: 50%;
    width: 36px;
    height: 2px;
    background: var(--line);
    transform: translateY(-50%);
  }

  .timeline-card {
    padding: 1rem 1.1rem;
    background: var(--card);
    border: 1px solid var(--border);
    border-radius: 18px;
    box-shadow: 0 10px 28px rgba(16, 24, 40, 0.06);
  }

  .timeline-card h3 {
    margin: 0 0 0.35rem;
    font-size: 1rem;
    line-height: 1.25;
    color: var(--text);
  }

  .timeline-card h3 a {
    color: inherit;
    text-decoration: none;
  }

  .timeline-card h3 a:hover {
    text-decoration: underline;
  }

  .timeline-card p {
    margin: 0;
    font-size: 0.95rem;
    line-height: 1.5;
    color: var(--muted);
  }

  @media (max-width: 860px) {
    .scaled-timeline {
      --axis-x: 28px;
      --card-gap: 34px;
    }

    .scaled-timeline__label {
      left: 18px;
      right: auto;
      top: -18px;
      transform: none;
    }

    .scaled-timeline__event {
      width: calc(100% - var(--axis-x) - var(--card-gap) - 8px);
    }

    .scaled-timeline__event::before {
      left: -22px;
      width: 22px;
    }
  }

  .scaled-timeline {
  --axis-x: 50%;
}

.scaled-timeline::before,
.scaled-timeline__tick {
  left: 50%;
}

.scaled-timeline__event {
  width: calc(50% - var(--card-gap) - 28px);
}

.scaled-timeline__event--left {
  left: auto;
  right: calc(50% + var(--card-gap));
}

.scaled-timeline__event--left::before {
  left: auto;
  right: -36px;
}

.scaled-timeline__event--left .timeline-card {
  text-align: right;
}

@media (max-width: 860px) {
  .scaled-timeline__event--left {
    right: auto;
    left: calc(var(--axis-x) + var(--card-gap));
  }

  .scaled-timeline__event--left::before {
    right: auto;
    left: -22px;
  }

  .scaled-timeline__event--left .timeline-card {
    text-align: left;
  }
}
</style>

